; ---------------------------------------------------------------------------
; TUNING NOTE (2026-03-16 v7) — Identity-driven stat floors
;
; Each gate checks only 2-3 stats that reflect the identity of that form.
; Floors calibrated against observed sim data (~65-70% of observed minimums).
;
; Khet average lifespan: 2190 days
; Stage split: 40% Rookie (876d) / 30% Pro (657d) / 30% Legend (657d)
;   Rookie->Pro gate opens:  876 days
;   Pro->Legend gate opens: 1533 days
;
; Gate identities:
;   Rookie->Pro  : Stamina + Technique  (the endurance specialist)
;   Legend A     : Technique + Charisma + Fame  (refined, commanding, known)
;   Legend B     : Power high + Charisma low  (the brute, crowd-indifferent)
;   Legend C     : Power + Technique + Charisma + Championship  (force, skill, presence)
;
; Observed stat ranges at gates (latest sim log):
;   At ~876 days:   STA min ~220  TEC min ~165
;   At ~1533 days:  POW min ~312  TEC min ~305  CHA min ~294
;
; Lifespan reference (336 days = 1 year):
;   4yr = 1344d (sabotage)    7yr = 2352d (good)
;   5yr = 1680d (unskilled)   8yr = 2688d (pushing it)
;   6yr = 2016d (average)     9yr = 3024d (concerted effort)
; ---------------------------------------------------------------------------

; --- Rookie to Pro ---
; Identity: the endurance specialist. Checks Stamina + Technique only.
; Floors at ~80% of observed minimums — clears immediately for any
; active trainer, but confirms the Khet identity is developing.

[sub_resource type="Resource" id="rtp_1"]
script = ExtResource("2_ec")
type = 4
days = 876

[sub_resource type="Resource" id="rtp_2"]
script = ExtResource("2_ec")
type = 8
stage = "Rookie"

[sub_resource type="Resource" id="rtp_3"]
script = ExtResource("2_ec")
type = 0
stat = "stamina"
value = 180.0

[sub_resource type="Resource" id="rtp_4"]
script = ExtResource("2_ec")
type = 0
stat = "technique"
value = 130.0

; --- Legend A (Nesut / Pharaoh) ---
; Identity: refined, commanding, known.
; Checks Technique + Charisma + Fame only.
; Floors at ~70% of observed minimums. Well-played clears immediately.
; A monster who neglected Technique or Charisma for a specialist build
; may need a few weeks after the window opens.

[sub_resource type="Resource" id="la_1"]
script = ExtResource("2_ec")
type = 8
stage = "Pro"

[sub_resource type="Resource" id="la_2"]
script = ExtResource("2_ec")
type = 4
days = 1533

[sub_resource type="Resource" id="la_3"]
script = ExtResource("2_ec")
type = 0
stat = "technique"
value = 210.0
hint_vague = "Needs refined Technique..."
hint_full = "Needs 210 Technique"

[sub_resource type="Resource" id="la_4"]
script = ExtResource("2_ec")
type = 0
stat = "charisma"
value = 200.0
hint_vague = "Needs commanding Charisma..."
hint_full = "Needs 200 Charisma"

[sub_resource type="Resource" id="la_5"]
script = ExtResource("2_ec")
type = 7
stat = "fame"
value = 40.0
hint_vague = "Needs to be known..."
hint_full = "Needs 40 Fame"

; --- Legend B (Mesu-Bathu / Revenant) ---
; Identity: the brute, crowd-indifferent.
; Checks Power high + Charisma low. Two stats, opposite directions.
; Observed power specialist at 1533 days: POW ~430-470, floor at 260
; is comfortably reachable with committed specialisation.
; Charisma cap 120: balanced monster has ~290-350 CHA at this point,
; so must actively neglect it throughout Pro stage.
; Sessions check (25) confirms the specialisation was intentional.

[sub_resource type="Resource" id="lb_1"]
script = ExtResource("2_ec")
type = 8
stage = "Pro"

[sub_resource type="Resource" id="lb_2"]
script = ExtResource("2_ec")
type = 4
days = 1533

[sub_resource type="Resource" id="lb_3"]
script = ExtResource("2_ec")
type = 3
stat = "power"
sessions = 25
hint_vague = "Seems to respond to repeated Power training..."
hint_full = "Needs 25 Power training sessions"

[sub_resource type="Resource" id="lb_4"]
script = ExtResource("2_ec")
type = 0
stat = "power"
value = 260.0
hint_vague = "Needs very high Power..."
hint_full = "Needs 260 Power"

[sub_resource type="Resource" id="lb_5"]
script = ExtResource("2_ec")
type = 1
stat = "charisma"
value = 120.0
hint_vague = "Something happens when the crowd doesn't warm to them..."
hint_full = "Needs Charisma below 120"

; --- Legend C (Aten-Ka / God-King) ---
