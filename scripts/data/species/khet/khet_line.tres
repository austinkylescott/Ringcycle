; --- Legend B (Mesu-Bathu / Revenant) conditions ---
; Specialist path. Heavy Power drilling + Charisma neglect.
; A player who intentionally focuses on Power and ignores Charisma hits this.
; Thresholds kept high enough to require genuine specialisation.

[sub_resource type="Resource" id="lb_1"]
script = ExtResource("2_ec")
type = 8
stage = "Pro"

[sub_resource type="Resource" id="lb_2"]
script = ExtResource("2_ec")
type = 3
stat = "power"
sessions = 35
hint_vague = "Seems to respond to repeated Power training..."
hint_full = "Needs 35 Power training sessions"

[sub_resource type="Resource" id="lb_3"]
script = ExtResource("2_ec")
