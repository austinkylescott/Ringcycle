# ---------------------------------------------------------------------------
# Aten-Ka — Mummy line Legend C (God-King)
# The against-grain path. Transcendence through total balance.
# All wrappings shed. Radiates golden light. No longer a mummy — a deity.
# Requires ALL six stats above a moderate threshold simultaneously.
# Hardest to achieve because it fights the natural drift toward specialization.
# ---------------------------------------------------------------------------

class_name WrestlerSpeciesResource

@export var id: String = "khet_legend_c"
@export var display_name: String = "Aten-Ka"
@export var stage: String = "Legend_C"

@export var base_stats := {
	"power":     45,
	"technique": 42,
	"agility":   38,
	"toughness": 48,
	"stamina":   50,
	"charisma":  42,
}

# God-King form: all stats grow equally and exceptionally
# The divine form has no weaknesses — everything ascends together
@export var growth_profile := {
	"power":     1.3,
	"technique": 1.3,
	"agility":   1.3,
	"toughness": 1.3,
	"stamina":   1.3,
	"charisma":  1.3,
}

# High uniform soft caps — the God-King can push everything to near-max
@export var soft_caps := {
	"power":     850,
	"technique": 850,
	"agility":   850,
	"toughness": 850,
	"stamina":   850,
	"charisma":  850,
}

@export var lifespan_base: int     = 2190
@export var lifespan_variance: int = 365
@export var lifespan_min: int      = 730

# Largest move pool — a god knows all things
@export var move_pool: Array[String] = [
	"bandage_bind",
	"dust_slam",
	"ancient_guard",
	"cursed_stare",
	"sarcophagus_drop",
	"scarab_swarm",
	"ankh_strike",
